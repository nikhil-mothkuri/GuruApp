PORT=4000
NODE_ENV=development

# PostgreSQL — local Docker: postgresql://postgres:postgres@localhost:5432/guruapp
# Neon free tier:           postgresql://user:pass@ep-xxx.region.aws.neon.tech/guruapp?sslmode=require
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/guruapp
TEST_DATABASE_URL=postgresql://postgres:postgres@localhost:5433/guruapp_test

JWT_ACCESS_SECRET=change_me_must_be_at_least_32_characters_long
JWT_REFRESH_SECRET=change_me_must_be_at_least_32_characters_long

JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

GOOGLE_CLIENT_ID=your_google_oauth_client_id.apps.googleusercontent.com

UPLOAD_DIR=uploads
MAX_FILE_SIZE_MB=5
