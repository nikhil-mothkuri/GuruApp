datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String?
  googleId     String?  @unique
  name         String
  bio          String?
  avatarUrl    String?
  isGuru       Boolean  @default(false)
  isStudent    Boolean  @default(true)
  isAdmin      Boolean  @default(false)
  isActive          Boolean   @default(true)
  failedLoginCount  Int       @default(0)
  lockedUntil       DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  guruProfile       GuruProfile?
  bookingsAsStudent Booking[]      @relation("StudentBookings")
  bookingsAsGuru    Booking[]      @relation("GuruBookings")
  ratingsGiven      Rating[]       @relation("RatingsGiven")
  favoritedBy       Favorite[]     @relation("FavoritedBy")
  refreshTokens     RefreshToken[]
  ordersAsGuru      Order[]        @relation("GuruOrders")
  ordersAsUser      Order[]        @relation("UserOrders")

  @@index([email])
}

model GuruProfile {
  id          String  @id @default(cuid())
  userId      String  @unique
  user        User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  tagline     String?
  ratingAvg   Float   @default(0)
  ratingCount Int     @default(0)

  skills    GuruSkill[]
  photos    GuruPhoto[]
  videos    GuruVideo[]
  slots     AvailabilitySlot[]
  favorites Favorite[]
  products  Product[]
}

model GuruSkill {
  id        String      @id @default(cuid())
  guruId    String
  guru      GuruProfile @relation(fields: [guruId], references: [id], onDelete: Cascade)
  skillName String

  @@unique([guruId, skillName])
  @@index([skillName])
}

model GuruPhoto {
  id           String      @id @default(cuid())
  guruId       String
  guru         GuruProfile @relation(fields: [guruId], references: [id], onDelete: Cascade)
  url          String
  caption      String?
  displayOrder Int         @default(0)
}

model GuruVideo {
  id           String      @id @default(cuid())
  guruId       String
  guru         GuruProfile @relation(fields: [guruId], references: [id], onDelete: Cascade)
  youtubeUrl   String
  title        String
  thumbnailUrl String?
}

model AvailabilitySlot {
  id               String      @id @default(cuid())
  guruId           String
  guru             GuruProfile @relation(fields: [guruId], references: [id], onDelete: Cascade)
  dayOfWeek        Int
  startTime        String
  endTime          String
  slotDurationMins Int         @default(60)
  isActive         Boolean     @default(true)
  bookings         Booking[]

  @@index([guruId, dayOfWeek])
}

// SQLite has no native enum — String fields validated by Zod in service layer
// type:   "SUBSCRIPTION" | "APPOINTMENT"
// status: "PENDING" | "CONFIRMED" | "COMPLETED" | "CANCELLED"
model Booking {
  id             String            @id @default(cuid())
  studentId      String
  student        User              @relation("StudentBookings", fields: [studentId], references: [id])
  guruId         String
  guru           User              @relation("GuruBookings", fields: [guruId], references: [id])
  slotId         String?
  slot           AvailabilitySlot? @relation(fields: [slotId], references: [id])
  type           String
  scheduledAt    DateTime
  recurrenceRule String?
  status         String            @default("PENDING")
  createdAt      DateTime          @default(now())
  rating         Rating?

  @@index([studentId, status])
  @@index([guruId, status])
  @@index([scheduledAt])
}

model Rating {
  id        String   @id @default(cuid())
  bookingId String   @unique
  booking   Booking  @relation(fields: [bookingId], references: [id])
  studentId String
  student   User     @relation("RatingsGiven", fields: [studentId], references: [id])
  guruId    String
  stars     Int
  comment   String?
  createdAt DateTime @default(now())

  @@index([guruId])
}

model Favorite {
  id        String      @id @default(cuid())
  studentId String
  student   User        @relation("FavoritedBy", fields: [studentId], references: [id])
  guruId    String
  guru      GuruProfile @relation(fields: [guruId], references: [id], onDelete: Cascade)

  @@unique([studentId, guruId])
}

model RefreshToken {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
}

// status: "ACTIVE" | "DRAFT" | "OUT_OF_STOCK" | "ARCHIVED"
model Product {
  id               String   @id @default(cuid())
  guruId           String
  guru             GuruProfile @relation(fields: [guruId], references: [id], onDelete: Cascade)
  name             String
  slug             String   @unique
  description      String?
  shortDescription String?
  price            Float
  compareAtPrice   Float?
  currency         String   @default("USD")
  sku              String?
  stock            Int      @default(0)
  lowStockThreshold Int     @default(5)
  isDigital        Boolean  @default(false)
  downloadUrl      String?
  category         String?
  tags             String?
  status           String   @default("DRAFT")
  weight           Float?
  weightUnit       String   @default("kg")
  length           Float?
  width            Float?
  height           Float?
  dimensionUnit    String   @default("cm")
  shippingRequired Boolean  @default(true)
  metaTitle        String?
  metaDescription  String?
  viewCount        Int      @default(0)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  images     ProductImage[]
  orderItems OrderItem[]

  @@index([guruId])
  @@index([category])
  @@index([status])
}

model ProductImage {
  id           String   @id @default(cuid())
  productId    String
  product      Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  url          String
  altText      String?
  displayOrder Int      @default(0)

  @@index([productId])
}

// status: "PENDING" | "CONFIRMED" | "SHIPPED" | "DELIVERED" | "CANCELLED" | "REFUNDED"
model Order {
  id              String   @id @default(cuid())
  guruId          String
  guru            User     @relation("GuruOrders", fields: [guruId], references: [id])
  userId          String?
  user            User?    @relation("UserOrders", fields: [userId], references: [id])
  buyerName       String
  buyerEmail      String
  buyerPhone      String?
  status          String   @default("PENDING")
  totalAmount     Float
  currency        String   @default("USD")
  shippingAddress String?
  shippingCity    String?
  shippingState   String?
  shippingCountry String?
  shippingZip     String?
  notes           String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  items OrderItem[]

  @@index([guruId])
  @@index([userId])
  @@index([buyerEmail])
  @@index([status])
}

model OrderItem {
  id          String  @id @default(cuid())
  orderId     String
  order       Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId   String
  product     Product @relation(fields: [productId], references: [id])
  productName String
  unitPrice   Float
  quantity    Int
  totalPrice  Float

  @@index([orderId])
  @@index([productId])
}
